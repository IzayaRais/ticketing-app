# ⚠️ IMPORTANT: Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!
# This file serves as a template for required environment variables

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# NextAuth Secret - Generate with: openssl rand -base64 32
# Used to encrypt session tokens and JWT tokens
NEXTAUTH_SECRET=your_nextauth_secret_here_change_me_in_production

# NextAuth URL - Full URL of your application
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# GOOGLE OAUTH & SERVICES
# ============================================================================

# Google OAuth Client ID
# Get from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google OAuth Client Secret
# ⚠️ SENSITIVE: Keep this secret! Only in .env.local
# Never commit or expose this value
GOOGLE_CLIENT_SECRET=your_google_client_secret_here_do_not_share

# Google Sheets ID (for data storage)
# Found in the URL: https://docs.google.com/spreadsheets/d/{SHEETS_ID}/edit
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Google Drive Folder ID (for file storage)
# Get from: https://drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ============================================================================
# EMAIL SERVICE (Nodemailer)
# ============================================================================

# SMTP Configuration for sending emails
# Using Gmail? Get an App Password from: https://myaccount.google.com/apppasswords
# Do NOT use your main Gmail password

# SMTP Server Host
SMTP_HOST=smtp.gmail.com

# SMTP Port (TLS: 587, SSL: 465)
SMTP_PORT=587

# SMTP Username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP Password (use App Password for Gmail)
# ⚠️ SENSITIVE: Keep this secret! Only in .env.local
SMTP_PASSWORD=your_app_specific_password_not_main_password

# Email address for sending notifications
SENDER_EMAIL=noreply@yourdomain.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# API Base URL (internal use)
# For development: http://localhost:3000
# For production: https://yourdomain.com
API_BASE_URL=http://localhost:3000

# Public Application URL (visible in client-side code)
# Must match NEXTAUTH_URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# DEVELOPMENT ONLY (Optional)
# ============================================================================

# Set to 'true' to enable verbose logging
# DEBUG=ticketing-app:*

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Create a copy of this file:
#    cp .env.example .env.local
#
# 2. Fill in all required values (marked with YOUR_VALUE)
#
# 3. Never commit .env.local to Git (see .gitignore)
#
# 4. For production, set the same variables in your hosting platform:
#    - Vercel: Project Settings > Environment Variables
#    - Other platforms: Set as system/build environment variables
#
# 5. For local development:
#    - Keep .env.local in root directory
#    - It will be loaded automatically by Next.js
#    - Restart `npm run dev` after changing values
